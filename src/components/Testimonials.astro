---
import { site } from '../data/site.ts';
const quotes = [
  {
    quote: "I've been training at Webb's for over 20 years — love the atmosphere, the people, and the owners, Linda and Monty Webb.",
    name: "Butch Williams",
    detail: "Member, 20+ years",
  },
  {
    quote: "I absolutely love Webb's! I've been a member for like 8 years. Best instructors — they teach you how to do things the correct way.",
    name: "Regina Schultz",
    detail: "Member, 8 years",
  },
  {
    quote: "Webb's is an awesome gym with everything you need to get a great workout. The staff is always extremely friendly and the gym is very clean. Highly recommend to anyone looking for a non-intimidating, family-owned gym!",
    name: "Jake Cuccia",
    detail: "Google review",
  },
  {
    quote: "Fantastic gym. Owner Monty is a great guy and everyone is very nice. The facility is super clean and there are a ton of weight machines — super welcoming for all levels of lifters.",
    name: "Brendan McGuire",
    detail: "Local Guide · Google review",
  },
];
---
<section class="section section--alt">
  <div class="container">
    <p class="kicker">What Members Say</p>
    <h2>Trusted by <span class="accent">Pittsburgh Lifters</span></h2>
    <p class="quotes__stat">Rated {site.rating}★ by {site.reviewCount}+ members · Family-owned for {site.yearsInBusiness} years</p>
    <div class="quotes">
      {quotes.map((q) => (
        <figure class="quote">
          <blockquote>"{q.quote}"</blockquote>
          <figcaption>— {q.name} <span>· {q.detail}</span></figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .quotes__stat { color: var(--gold); font-size: 0.95rem; margin: 8px 0 0; }
  .quotes { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 32px; }
  .quote { margin: 0; background: var(--charcoal); border-radius: 12px; padding: 28px 24px; border-top: 3px solid var(--gold); }
  .quote blockquote { margin: 0 0 14px; font-size: 1.05rem; color: var(--cream); line-height: 1.5; }
  .quote figcaption { color: var(--gold); font-size: 0.9rem; letter-spacing: 0.5px; }
  .quote figcaption span { color: var(--muted); }
  @media (max-width: 820px) { .quotes { grid-template-columns: 1fr; } }
</style>
