---
import { site } from '../data/site.ts';
---
<section class="section" id="contact">
  <div class="container contact">
    <p class="kicker">Get in Touch</p>
    <h2>Send Us a Message</h2>
    <p class="contact__lead">Questions about membership, classes, or personal training? Send a note and we'll get back to you.</p>

    <form class="contact__form" data-contact-form action={site.contactEndpoint || undefined} method="POST">
      <div class="contact__row">
        <input type="text" name="name" placeholder="Your name" required />
        <input type="email" name="email" placeholder="Your email" required />
      </div>
      <textarea name="message" rows="4" placeholder="How can we help?" required></textarea>
      <button type="submit" class="btn-gold">Send Message</button>
      <p class="contact__status" data-contact-status aria-live="polite"></p>
    </form>
  </div>
</section>

<style>
  .contact { text-align: center; }
  .contact__lead { color: var(--muted); max-width: 560px; margin: 0 auto 28px; }
  .contact__form { max-width: 620px; margin: 0 auto; }
  .contact__row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
  .contact__form input,
  .contact__form textarea {
    width: 100%; background: var(--charcoal-2); color: var(--cream);
    border: 1px solid rgba(198,164,92,0.22); border-radius: 8px;
    padding: 13px 14px; font: 400 0.98rem "Inter", sans-serif; resize: vertical;
  }
  .contact__form input::placeholder,
  .contact__form textarea::placeholder { color: #8a8275; }
  .contact__form input:focus,
  .contact__form textarea:focus { outline: none; border-color: var(--gold); }
  .contact__form textarea { margin-bottom: 16px; }
  .contact__status { color: var(--gold); font-size: 0.92rem; min-height: 1.2em; margin: 12px 0 0; }
  @media (max-width: 560px) { .contact__row { grid-template-columns: 1fr; } }
</style>

<script define:vars={{ email: site.email, endpoint: site.contactEndpoint }}>
  const form = document.querySelector('[data-contact-form]');
  const status = document.querySelector('[data-contact-status]');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      // No backend endpoint configured: open the visitor's email app prefilled.
      if (!endpoint) {
        const subject = `Website inquiry from ${data.get('name') || 'a visitor'}`;
        const body = `Name: ${data.get('name') || ''}\nEmail: ${data.get('email') || ''}\n\n${data.get('message') || ''}`;
        window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        status.textContent = 'Opening your email app…';
        return;
      }
      // Endpoint configured (e.g. Formspree): submit in the background.
      status.textContent = 'Sending…';
      try {
        const res = await fetch(endpoint, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
        if (res.ok) { form.reset(); status.textContent = "Thanks — we'll be in touch soon."; }
        else { status.textContent = 'Something went wrong. Please call us at 412-798-2800.'; }
      } catch {
        status.textContent = 'Something went wrong. Please call us at 412-798-2800.';
      }
    });
  }
</script>
