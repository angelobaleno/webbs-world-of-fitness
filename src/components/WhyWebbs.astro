---
const points = [
  { title: "Full Weight Floor", body: "A full weight-training floor built for real lifting — free weights, Olympic platforms, and the equipment to back any program." },
  { title: "Expert Coaching", body: "Personalized programs for weight loss, rehab, flexibility, functional strength, Olympic lifting, and natural bodybuilding." },
  { title: "Everyone's Welcome", body: "Hardcore where it counts, friendly everywhere else. Every level belongs here — beginners included." },
  { title: "Family-Run & Local", body: "A Pittsburgh staple run by Linda & Monty Webb, with the experience and community to match." },
];
---
<section class="section section--alt" id="about">
  <div class="container">
    <p class="kicker">Why Webb's</p>
    <h2>More Than <span class="accent">a Gym</span></h2>
    <div class="why__grid">
      {points.map((p, i) => (
        <article class="why__card">
          <span class="why__num">{String(i + 1).padStart(2, '0')}</span>
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-top: 40px; }
  .why__card {
    background: var(--charcoal);
    border: 1px solid var(--line);
    border-radius: 12px; padding: 26px 22px;
    transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease;
  }
  .why__card:hover { transform: translateY(-3px); background: var(--charcoal-3); border-color: rgba(198,164,92,0.35); }
  .why__num { font-family: "Oswald", sans-serif; font-weight: 600; font-size: 1.3rem; letter-spacing: 1px; color: var(--gold); opacity: 0.7; }
  .why__card h3 { color: var(--cream); margin-top: 12px; }
  .why__card p { color: var(--muted); font-size: 0.95rem; margin: 0; }
  @media (max-width: 900px) { .why__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .why__grid { grid-template-columns: 1fr; } }
</style>
