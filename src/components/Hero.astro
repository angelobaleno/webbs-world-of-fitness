---
import { site } from '../data/site.ts';
---
<section class="hero" style={`--hero-img: url("${import.meta.env.BASE_URL}/images/hero-floor.webp")`}>
  <div class="container hero__inner">
    <p class="kicker">Natural Bodybuilding · All Levels Welcome</p>
    <h1 class="hero__title">{site.tagline}</h1>
    <p class="hero__sub">
      Real weights, expert coaching, and a room that's serious about training
      and easy to walk into — day one or year ten.
    </p>
    <a class="btn-gold" href="#membership">Join Today</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex; align-items: center;
    background-color: var(--charcoal-2);
    background-image:
      linear-gradient(90deg, rgba(12,10,7,0.90) 0%, rgba(12,10,7,0.55) 58%, rgba(12,10,7,0.40) 100%),
      linear-gradient(180deg, rgba(12,10,7,0.20) 0%, rgba(12,10,7,0.82) 100%),
      var(--hero-img);
    background-size: cover;
    background-position: center;
  }
  .hero__inner { max-width: 720px; }
  .hero__title { font-size: clamp(2.8rem, 7vw, 5rem); font-weight: 700; margin-bottom: 18px; }
  .hero__sub { font-size: 1.15rem; color: var(--muted); max-width: 540px; margin: 0 0 28px; }
</style>
