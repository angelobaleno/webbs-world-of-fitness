---
import { site } from '../data/site.ts';
// Split the tagline so the final word can carry the italic serif accent.
const words = site.tagline.trim().split(' ');
const lastWord = words.pop();
const leadWords = words.join(' ');
const estYear = new Date().getFullYear() - site.yearsInBusiness;
const stats = [
  { big: site.yearsInBusiness, label: 'Years Open' },
  { big: `${site.rating}★`, label: `${site.reviewCount}+ Reviews` },
  { big: '$0', label: 'Initiation Fees' },
  { big: '7', label: 'Days a Week' },
];
---
<section class="hero" style={`--hero-img: url("${import.meta.env.BASE_URL}/images/hero-floor.webp")`}>
  <div class="container hero__inner">
    <span class="hero__est">Est. {estYear} · <b>{site.yearsInBusiness} Years in Pittsburgh</b></span>
    <p class="kicker hero__kicker">Natural Bodybuilding · All Levels Welcome</p>
    <h1 class="hero__title">{leadWords} <span class="accent">{lastWord}</span></h1>
    <p class="hero__sub">
      Real weights, expert coaching, and a room that's serious about training
      and easy to walk into — day one or year ten.
    </p>
    <div class="hero__cta">
      <a class="btn-gold" href="#membership">Join Today</a>
      <a class="hero__ghost" href="#membership">See Memberships →</a>
    </div>
  </div>
  <div class="hero__stats">
    <div class="container hero__stats-row">
      {stats.map((s) => (
        <div class="hero__stat"><b>{s.big}</b><span>{s.label}</span></div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex; align-items: center;
    background-color: var(--charcoal-2);
    background-image:
      linear-gradient(90deg, rgba(8,6,4,0.94) 0%, rgba(8,6,4,0.76) 44%, rgba(8,6,4,0.34) 100%),
      linear-gradient(0deg, rgba(8,6,4,0.92) 0%, rgba(8,6,4,0) 46%),
      var(--hero-img);
    background-size: cover;
    background-position: center 40%;
    /* rescue the dark, low-contrast source photo */
    background-blend-mode: normal, normal, normal;
  }
  .hero__inner { max-width: 720px; padding-bottom: 88px; }
  .hero__est {
    display: inline-flex; align-items: center; gap: 8px;
    margin-bottom: 22px; padding: 7px 14px;
    border: 1px solid var(--line); border-radius: 100px;
    font-family: "Oswald", sans-serif; font-size: 0.72rem;
    letter-spacing: 2.5px; text-transform: uppercase; color: var(--gold);
  }
  .hero__est b { color: var(--cream); font-weight: 600; }
  .hero__kicker { margin-bottom: 10px; }
  .hero__title { font-size: clamp(3rem, 7.5vw, 5.6rem); font-weight: 700; line-height: 0.95; margin-bottom: 20px; }
  .hero__sub { font-size: 1.12rem; color: var(--cream); opacity: 0.86; max-width: 460px; margin: 0 0 30px; }
  .hero__cta { display: flex; gap: 18px; align-items: center; flex-wrap: wrap; }
  .hero__ghost {
    font-family: "Oswald", sans-serif; text-transform: uppercase; letter-spacing: 2px;
    font-size: 0.84rem; color: var(--cream); border-bottom: 1px solid var(--gold); padding-bottom: 3px;
  }
  .hero__ghost:hover { color: var(--gold); }

  .hero__stats {
    position: absolute; bottom: 0; left: 0; right: 0;
    border-top: 1px solid var(--line);
    background: rgba(8,6,4,0.55); backdrop-filter: blur(5px);
  }
  .hero__stats-row { display: flex; }
  .hero__stat {
    flex: 1; padding: 20px 8px; text-align: center;
    border-right: 1px solid var(--line);
  }
  .hero__stat:last-child { border-right: 0; }
  .hero__stat b { display: block; font-family: "Oswald", sans-serif; font-weight: 600; font-size: 1.7rem; color: var(--gold); line-height: 1; }
  .hero__stat span { font-size: 0.72rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); }

  @media (max-width: 620px) {
    .hero__inner { padding-bottom: 120px; }
    .hero__stats-row { flex-wrap: wrap; }
    .hero__stat { flex: 1 0 50%; border-bottom: 1px solid var(--line); }
    .hero__stat:nth-child(2) { border-right: 0; }
  }
</style>
